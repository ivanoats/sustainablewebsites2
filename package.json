{
  "name": "sustainable-websites-com",
  "version": "2.0.0",
  "description": "Website for marketing green website services",
  "license": "none",
  "author": "Ivan Storck",
  "type": "module",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "panda:codegen": "panda codegen",
    "panda:css": "panda cssgen",
    "panda:gen": "npm run panda:codegen && npm run panda:css",
    "predev": "npm run panda:gen",
    "pretype-check": "npm run panda:gen",
    "prebuild": "npm run panda:gen",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!**/node_modules/**\"",
    "lint-staged": "lint-staged",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky",
    "test": "vitest --passWithNoTests",
    "test:ui": "vitest --ui",
    "screenshots:before": "cross-env SCREENSHOT_DIR=screenshots/before playwright test e2e/screenshots.spec.ts",
    "screenshots:after": "cross-env SCREENSHOT_DIR=screenshots/after playwright test e2e/screenshots.spec.ts",
    "screenshots": "cross-env SCREENSHOT_DIR=screenshots/manual playwright test e2e/screenshots.spec.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": "prettier --write",
    "*.md": [
      "markdownlint-cli2",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ark-ui/react": "^5.34.0",
    "@pandacss/dev": "^1.8.2",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.6.17",
    "@storybook/react": "^8.6.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.0",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
